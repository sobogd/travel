generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Local copy of the world's airports (seeded from OurAirports). Code = IATA.
model Airport {
  code    String  @id // IATA, e.g. "OVD"
  icao    String?
  name    String
  city    String?
  country String // ISO country code, e.g. "ES"
  lat     Float?
  lon     Float?

  @@index([country])
  @@map("airports")
}

// One connection search (A→B with custom layover), tied to an owner (history).
model Search {
  id            String   @id @default(cuid())
  ownerKey      String? // "telegram:<id>" | "device:<uuid>"
  originCode    String
  destCode      String
  dateFrom      String // YYYY-MM-DD (period start)
  dateTo        String // YYYY-MM-DD (period end)
  maxDistKm     Int // nearby-airport ground radius
  maxLayoverMin Int // ceiling for connection time
  results       Json // Itinerary[]
  createdAt     DateTime @default(now())

  @@index([ownerKey])
  @@map("searches")
}

// Cached chunk of an airport's FIDS — one row = one 12h AeroDataBox call.
// flights: ParsedFlight[] (see lib/aerodatabox.ts).
model FidsCache {
  id          String   @id @default(cuid())
  airportCode String // IATA of the queried airport
  direction   String // "Departure" | "Arrival"
  date        String // YYYY-MM-DD (airport local)
  half        String // "AM" (00–12) | "PM" (12–24)
  flights     Json
  fetchedAt   DateTime @default(now())

  @@unique([airportCode, direction, date, half])
  @@map("fids_cache")
}
